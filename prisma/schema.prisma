generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id         String    @id
  domain     String    @unique
  plan       String?
  currency   String?
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

enum RenderType {
  POPUP
  EMBEDDED
}

enum TargetType {
  PRODUCTS
  VARIANTS
  COLLECTIONS
  ALL
}

model Warning {
  id                    String        @id @default(cuid())
  shop                  String
  name                  String
  allowCheckout         Boolean       @default(true)
  renderType            RenderType    @default(POPUP)
  content               String        @default("")
  specialLineItemText   String?
  designOverride        Json?
  scheduleStart         DateTime?
  scheduleEnd           DateTime?
  visibilityOnAddToCart Boolean       @default(true)
  visibilityOnBuyNow    Boolean       @default(false)
  isActive              Boolean       @default(true)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  targets               WarningTarget[]
}

model WarningTarget {
  id         String     @id @default(cuid())
  warningId  String
  targetType TargetType @default(ALL)
  targetIds  String[]
  warning    Warning    @relation(fields: [warningId], references: [id], onDelete: Cascade)
}

model ShopSettings {
  id                    String   @id @default(cuid())
  shop                  String   @unique
  appEmbedEnabled       Boolean  @default(false)
  addToCartSelector     String   @default("")
  customCSS             String?
  showOnCollectionPages Boolean  @default(true)
  designDefaults        Json?
  storefrontApiToken    String?
  planName              String   @default("FREE")
  planCheckedAt         DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
